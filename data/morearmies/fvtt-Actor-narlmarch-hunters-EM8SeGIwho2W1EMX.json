    {
      "folder": "e185cDQaLjU3uZ62",
      "img": "icons/sundries/books/book-red-exclamation.webp",
      "name": "Sharpshooter",
      "system": {
        "description": {
          "gm": "",
          "value": "<p>The commander drills the army in precision ranged attacks. You gain a +1 status bonus on attacks with ranged Strikes, but suffer a –2 status bonus on attacks with melee Strikes. At 9th level, the penalty to melee Strikes is reduced to –1, and at 15th level the penalty to melee Strikes is removed.</p>\n<p>The army can use the @UUID[Compendium.pf2e.kingmaker-features.Item.GIbm9qo8VuFgPywJ]{Covering Fire} tactical war action.</p>"
        },
        "rules": [
          {
            "key": "GrantItem",
            "uuid": "Compendium.pf2e.kingmaker-features.Item.GIbm9qo8VuFgPywJ"
          },
          {
            "key": "FlatModifier",
            "selector": "ranged-attack-roll",
            "type": "status",
            "value": 1
          },
          {
            "key": "FlatModifier",
            "selector": "melee-attack-roll",
            "type": "status",
            "value": "match(when(btwn(@actor.level, 1, 8), -2), when(btwn(@actor.level, 9, 14), -1), when(gte(@actor.level, 15), 0))"
          }
        ],
        "slug": "sharpshooter",
